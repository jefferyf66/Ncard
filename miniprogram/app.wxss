page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1F2937;
  background-color: #F9FAFB;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

view, text {
  box-sizing: border-box;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  line-height: inherit;
}

button::after {
  border: none;
}

button:focus {
  outline: none;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
}

.avatar {
  border-radius: 50%;
  background-color: #F9FAFB;
}
