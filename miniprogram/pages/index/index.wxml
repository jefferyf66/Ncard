<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">我的名片</text>
      <text class="subtitle" wx:if="{{!isLoading && !isError}}">{{cards.length}} 张名片</text>
    </view>
    <view class="header-actions">
      <view class="header-btn" bindtap="addToDesktop">
        <view class="header-icon-wrapper small">
          <view class="icon-desktop"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-state" wx:elif="{{isEmpty}}">
    <view class="empty-content">
      <view class="empty-icon">
        <view class="icon-card"></view>
      </view>
      <text class="empty-title">暂无名片</text>
      <text class="empty-desc">点击右上角创建您的第一张名片</text>
      <view class="empty-btn" bindtap="goToEdit">创建名片</view>
    </view>
  </view>

  <view class="card-list" wx:else>
    <view 
      wx:for="{{cards}}" 
      wx:key="_id" 
      class="card-item"
      bindtap="goToPreview"
      data-id="{{item._id}}"
    >
      <!-- 优化后卡片布局：参考设计稿 -->
      <view class="card-wrapper">
        <view class="card-top">
          <view class="card-avatar-wrapper">
            <image 
              class="card-avatar" 
              src="{{item.avatar || '../../images/avatar.png'}}" 
              mode="aspectFill"
              lazy-load
              binderror="onAvatarError"
              data-index="{{index}}"
            ></image>
          </view>
          <view class="card-header-info">
            <text class="card-name">{{item.name || '未命名'}}</text>
            <text class="card-position" wx:if="{{item.position}}">{{item.position}}</text>
          </view>
        </view>
        <view class="card-divider"></view>
        <view class="card-body">
          <text class="card-company">{{item.company || ''}}</text>
          <view class="card-contact">
            <view class="contact-item" wx:if="{{item.phone}}">
              <text>{{item.phone}}</text>
            </view>
            <view class="contact-item" wx:if="{{item.email}}">
              <text>{{item.email}}</text>
            </view>
            <view class="contact-item" wx:if="{{item.address}}">
              <text>{{item.address}}</text>
            </view>
          </view>
        </view>
        <view class="card-footer">
          <view class="send-card-btn" bindtap="goToEdit" catchtap="stopPropagation">
            <text class="send-icon">↑</text>
            <text class="send-text">发名片</text>
          </view>
          <view class="card-arrow">›</view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore && !isLoading}}">
      <view class="load-more-content">
        <view class="load-more-spinner"></view>
        <text>加载更多...</text>
      </view>
    </view>
    <view class="no-more" wx:elif="{{!hasMore && cards.length > 0}}">
      <text>— 已加载全部 —</text>
    </view>
  </view>

  <view class="visitors-section" wx:if="{{!isLoading && !isError && !isEmpty}}">
    <view class="section-header">
      <text class="section-title">名片数据</text>
      <view class="section-arrow" bindtap="goToVisitors">
        <text>查看更多 ›</text>
      </view>
    </view>

    <view class="stats-card">
      <view class="stat-item" bindtap="goToVisitors">
        <view class="stat-icon">
          <view class="icon-users"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.visitors}}</text>
          <text class="stat-label">我的访客</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">
          <view class="icon-eye"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.viewed}}</text>
          <text class="stat-label">多次来访</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goToCardList">
        <view class="stat-icon">
          <view class="icon-add"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.newCards}}</text>
          <text class="stat-label">名片数</text>
        </view>
      </view>
    </view>

    <view class="section-header">
      <text class="section-title">最近访客</text>
    </view>

    <view class="visitor-list">
      <view 
        class="visitor-item" 
        wx:for="{{recentVisitors}}" 
        wx:key="id"
        bindtap="goToVisitorDetail"
        data-item="{{item}}"
      >
        <view class="visitor-avatar">
          <image 
            wx:if="{{item.avatar}}"
            class="visitor-avatar-img" 
            src="{{item.avatar}}" 
            mode="aspectFill"
            binderror="onVisitorAvatarError"
            data-index="{{index}}"
          ></image>
          <view class="icon-user" wx:else></view>
        </view>
        <view class="visitor-content">
          <view class="visitor-header">
            <text class="visitor-name">{{item.name}}</text>
            <view class="visitor-level-badge level-{{item.visitorLevel}}" wx:if="{{item.isAnonymous}}">
              <text>匿名</text>
            </view>
            <text class="visitor-time">{{item.lastVisit}}</text>
          </view>
          <text class="visitor-position" wx:if="{{item.position}}">{{item.position}}</text>
          <view class="visitor-tags">
            <text class="tag visit-count-tag" wx:if="{{item.visitCount > 1}}">访问 {{item.visitCount}} 次</text>
            <text class="tag" wx:for="{{item.actions}}" wx:key="index">{{item}}</text>
          </view>
        </view>
        <view 
          class="visitor-button {{item.buttonType}}" 
          catchtap="handleVisitorAction"
          data-item="{{item}}"
        >
          {{item.buttonText}}
        </view>
      </view>
    </view>

    <view class="view-all-btn" bindtap="goToVisitors">
      <text>查看全部访客</text>
    </view>
  </view>

  <!-- 新增名片悬浮按钮 -->
  <view class="add-btn" bindtap="goToEdit">
    <text class="add-btn-icon">+</text>
  </view>

  <!-- 隐私授权弹窗 -->
  <view class="privacy-mask" wx:if="{{showPrivacyPopup}}" catchtouchmove="preventTouchMove">
    <view class="privacy-popup" catchtouchmove="preventTouchMove">
      <view class="privacy-popup-header">
        <text class="privacy-popup-title">用户隐私保护提示</text>
      </view>
      <view class="privacy-popup-body">
        <text class="privacy-popup-text">
          为了更好地保障您的合法权益，请您阅读并同意
          <text class="privacy-link" bindtap="openPrivacyPolicy">《隐私政策》</text>
          和
          <text class="privacy-link" bindtap="openServiceAgreement">《用户服务协议》</text>
          。我们将按照协议内容收集、使用和存储您的信息，包括您创建名片时填写的姓名、公司、手机号、邮箱等信息。
        </text>
      </view>
      <view class="privacy-popup-footer">
        <view class="privacy-btn-decline" bindtap="handlePrivacyDecline">
          <text>不同意</text>
        </view>
        <button class="privacy-btn-agree" id="agree-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="handlePrivacyAgree">
          同意
        </button>
      </view>
    </view>
  </view>

  <!-- 底部协议入口 -->
  <view class="agreement-footer" wx:if="{{!showPrivacyPopup}}">
    <text class="agreement-link" bindtap="openPrivacyPolicy">隐私政策</text>
    <text class="agreement-sep">|</text>
    <text class="agreement-link" bindtap="openServiceAgreement">用户服务协议</text>
  </view>
</view>
