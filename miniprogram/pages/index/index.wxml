<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">жҲ‘зҡ„еҗҚзүҮ</text>
      <text class="subtitle" wx:if="{{!isLoading && !isError}}">{{cards.length}} еј еҗҚзү?/text>
    </view>
    <view class="header-actions">
      <view class="header-btn" bindtap="addToDesktop">
        <view class="header-icon-wrapper small">
          <view class="icon-desktop"></view>
        </view>
      </view>
      <view class="add-btn" bindtap="goToEdit">
        <view class="add-icon-wrapper">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">еҠ иҪҪдё?..</text>
  </view>

  <view class="empty-state" wx:elif="{{isEmpty}}">
    <view class="empty-content">
      <view class="empty-icon">
        <view class="icon-card"></view>
      </view>
      <text class="empty-title">жҡӮж— еҗҚзүҮ</text>
      <text class="empty-desc">зӮ№еҮ»еҸідёҠи§’еҲӣе»әжӮЁзҡ„з¬¬дёҖеј еҗҚзү?/text>
      <view class="empty-btn" bindtap="goToEdit">еҲӣе»әеҗҚзүҮ</view>
    </view>
  </view>

  <view class="card-list" wx:else>
    <view 
      wx:for="{{cards}}" 
      wx:key="_id" 
      class="card-item"
      bindtap="goToPreview"
      data-id="{{item._id}}"
    >
      <view class="card-left">
        <image 
          class="card-avatar" 
          src="{{item.avatar || '../../images/avatar.png'}}" 
          mode="aspectFill"
          lazy-load
        ></image>
      </view>
      <view class="card-center">
        <view class="card-name-row">
          <text class="card-name">{{item.name || 'жңӘе‘Ҫеҗ?}}</text>
          <text class="card-position" wx:if="{{item.position}}">{{item.position}}</text>
        </view>
        <text class="card-company">{{item.company || ''}}</text>
        <view class="card-meta" wx:if="{{item.phone || item.email}}">
          <view class="meta-item" wx:if="{{item.phone}}">
            <view class="meta-icon icon-phone"></view>
            <text>{{item.phone}}</text>
          </view>
          <view class="meta-item" wx:if="{{item.email}}">
            <view class="meta-icon icon-mail"></view>
            <text>{{item.email}}</text>
          </view>
        </view>
      </view>
      <view class="card-right">
        <view class="card-arrow">вҖ?/view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore && !isLoading}}">
      <view class="load-more-content">
        <view class="load-more-spinner"></view>
        <text>еҠ иҪҪжӣҙеӨҡ...</text>
      </view>
    </view>
    <view class="no-more" wx:elif="{{!hasMore && cards.length > 0}}">
      <text>вҖ?е·ІеҠ иҪҪе…Ёйғ?вҖ?/text>
    </view>
  </view>

  <view class="visitors-section" wx:if="{{!isLoading && !isError && !isEmpty}}">
    <view class="section-header">
      <text class="section-title">еҗҚзүҮж•°жҚ®</text>
      <view class="section-arrow" bindtap="goToVisitors">
        <text>жҹҘзңӢжӣҙеӨҡ вҖ?/text>
      </view>
    </view>

    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-icon">
          <view class="icon-users"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.visitors}}</text>
          <text class="stat-label">и®ҝе®ў</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">
          <view class="icon-eye"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.viewed}}</text>
          <text class="stat-label">зңӢиҝҮ</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">
          <view class="icon-add"></view>
        </view>
        <view class="stat-info">
          <text class="stat-value">{{visitorStats.newCards}}</text>
          <text class="stat-label">ж–°еҗҚзү?/text>
        </view>
      </view>
    </view>

    <view class="section-header">
      <text class="section-title">жңҖиҝ‘и®ҝе®?/text>
    </view>

    <view class="visitor-list">
      <view 
        class="visitor-item" 
        wx:for="{{recentVisitors}}" 
        wx:key="id"
        bindtap="goToVisitorDetail"
        data-item="{{item}}"
      >
        <view class="visitor-avatar">
          <view class="icon-user"></view>
        </view>
        <view class="visitor-content">
          <view class="visitor-header">
            <text class="visitor-name">{{item.name}}</text>
            <text class="visitor-time">{{item.lastVisit}}</text>
          </view>
          <text class="visitor-position" wx:if="{{item.position}}">{{item.position}}</text>
          <view class="visitor-tags">
            <text class="tag" wx:for="{{item.actions}}" wx:key="index">{{item}}</text>
          </view>
        </view>
        <view 
          class="visitor-button {{item.buttonType}}" 
          bindtap="handleVisitorAction"
          data-item="{{item}}"
        >
          {{item.buttonText}}
        </view>
      </view>
    </view>

    <view class="view-all-btn" bindtap="goToVisitors">
      <text>жҹҘзңӢе…ЁйғЁи®ҝе®ў</text>
    </view>
  </view>

  <!-- йҡҗз§ҒжҺҲжқғеј№зӘ— -->
  <view class="privacy-mask" wx:if="{{showPrivacyPopup}}" catchtouchmove="preventTouchMove">
    <view class="privacy-popup" catchtouchmove="preventTouchMove">
      <view class="privacy-popup-header">
        <text class="privacy-popup-title">з”ЁжҲ·йҡҗз§ҒдҝқжҠӨжҸҗзӨә</text>
      </view>
      <view class="privacy-popup-body">
        <text class="privacy-popup-text">
          дёәдәҶжӣҙеҘҪең°дҝқйҡңжӮЁзҡ„еҗҲжі•жқғзӣҠпјҢиҜ·жӮЁйҳ…иҜ»е№¶еҗҢж„?          <text class="privacy-link" bindtap="openPrivacyPolicy">гҖҠйҡҗз§Ғж”ҝзӯ–гҖ?/text>
          е’?          <text class="privacy-link" bindtap="openServiceAgreement">гҖҠз”ЁжҲ·жңҚеҠЎеҚҸи®®гҖ?/text>
          гҖӮжҲ‘д»¬е°ҶжҢүз…§еҚҸи®®еҶ…е®№ж”¶йӣҶгҖҒдҪҝз”Ёе’ҢеӯҳеӮЁжӮЁзҡ„дҝЎжҒҜпјҢеҢ…жӢ¬жӮЁеҲӣе»әеҗҚзүҮж—¶еЎ«еҶҷзҡ„е§“еҗҚгҖҒе…¬еҸёгҖҒжүӢжңәеҸ·гҖҒйӮ®з®ұзӯүдҝЎжҒҜгҖ?        </text>
      </view>
      <view class="privacy-popup-footer">
        <view class="privacy-btn-decline" bindtap="handlePrivacyDecline">
          <text>дёҚеҗҢж„?/text>
        </view>
        <button class="privacy-btn-agree" id="agree-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="handlePrivacyAgree">
          еҗҢж„Ҹ
        </button>
      </view>
    </view>
  </view>

  <!-- еә•йғЁеҚҸи®®е…ҘеҸЈ -->
  <view class="agreement-footer" wx:if="{{!showPrivacyPopup}}">
    <text class="agreement-link" bindtap="openPrivacyPolicy">йҡҗз§Ғж”ҝзӯ–</text>
    <text class="agreement-sep">|</text>
    <text class="agreement-link" bindtap="openServiceAgreement">з”ЁжҲ·жңҚеҠЎеҚҸи®®</text>
  </view>
</view>
