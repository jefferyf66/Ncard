/* ==========================================
   Ncard 首页 · Hybrid 设计系统
   B 钴蓝基座 × D 编辑字体钮形 × C 暖调渐变
   ========================================== */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(175deg, #EFF6FF 0%, #F8FAFC 40%, #FEFCF7 100%);
}

/* ============ HEADER ============ */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 0 40rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 48rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -1rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
}

/* 添加按钮 — D方向：2px锐利方形 */
.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-icon-wrapper {
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #E2E8F0;
  transition: all 0.2s;
}

.header-icon-wrapper:active {
  transform: scale(0.95);
  border-color: #3B82F6;
}

.icon-desktop {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

/* 桌面图标：显示器 */
.icon-desktop::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 20rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 3rpx;
}

/* 桌面图标：支架 */
.icon-desktop::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 2rpx;
  background: #3B82F6;
  box-shadow: 0 -6rpx 0 #3B82F6;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon-wrapper {
  width: 100%;
  height: 100%;
  background: #3B82F6;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.18);
  transition: transform 0.2s, box-shadow 0.2s;
}

.add-icon-wrapper:active {
  transform: scale(0.95);
  background: #2563EB;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.14);
}

.add-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  font-family: Georgia, 'Times New Roman', serif;
}

/* ============ CARD LIST ============ */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx 24rpx 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.04), 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  border: 2rpx solid #E2E8F0;
  position: relative;
  overflow: hidden;
}

/* D方向：左侧品牌色装饰条 */
.card-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 6rpx;
  background: linear-gradient(180deg, #3B82F6 0%, #60A5FA 60%, #3B82F6 100%);
  border-radius: 0 3rpx 3rpx 0;
}

.card-item:active {
  transform: scale(0.985);
  box-shadow: 0 1rpx 6rpx rgba(29, 78, 216, 0.02), 0 1rpx 2rpx rgba(0, 0, 0, 0.03);
  border-color: #CBD5E1;
}

.card-left {
  flex-shrink: 0;
}

/* 头像 — D方向：方形锐角 */
.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 4rpx;
  border: 2rpx solid #E2E8F0;
  background: #F1F5F9;
}

.card-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* 名称 — D方向：衬线字体 */
.card-name {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 34rpx;
  font-weight: 600;
  color: #0F172A;
}

/* 职位标签 — 品牌蓝底 + 锐角 */
.card-position {
  font-size: 22rpx;
  font-weight: 500;
  color: #3B82F6;
  padding: 4rpx 14rpx;
  background: rgba(59, 130, 246, 0.06);
  border-radius: 4rpx;
}

.card-company {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: left;
}

.card-meta {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.meta-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

/* 联系方式区域 */
.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 单个联系信息项 - 右对齐 */
.info-item {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

/* 电话图标 */
.info-item .icon-phone {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  position: relative;
  opacity: 0.6;
}

.info-item .icon-phone::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  height: 2rpx;
  background: #3B82F6;
}

.info-item .icon-phone::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 8rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 0 0 6rpx 6rpx;
  border-top: none;
}

/* 邮件图标 */
.info-item .icon-mail {
  width: 32rpx;
  height: 24rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 3rpx;
  position: relative;
  opacity: 0.6;
}

.info-item .icon-mail::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 8rpx solid #3B82F6;
}

/* 地址图标 */
.info-item .icon-address {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.info-item .icon-address::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  opacity: 0.6;
}

.info-item .icon-address::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid #3B82F6;
  opacity: 0.6;
}

/* 电话图标 — 品牌色 */
.icon-phone {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  position: relative;
  opacity: 0.6;
}

.icon-phone::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  height: 2rpx;
  background: #3B82F6;
}

.icon-phone::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 10rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 0 0 8rpx 8rpx;
  border-top: none;
}

/* 邮件图标 — 品牌色 */
.icon-mail {
  width: 36rpx;
  height: 28rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.6;
}

.icon-mail::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 8rpx solid #3B82F6;
}

.card-right {
  flex-shrink: 0;
}

.card-arrow {
  font-size: 44rpx;
  color: #94A3B8;
}

/* ============ LOADING ============ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* ============ EMPTY STATE ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-card {
  width: 100rpx;
  height: 60rpx;
  border: 3rpx solid #3B82F6;
  border-radius: 8rpx;
  position: relative;
}

.icon-card::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #64748B;
  border-radius: 50%;
}

.icon-card::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 40rpx;
  width: 4rpx;
  height: 4rpx;
  background: #64748B;
  border-radius: 50%;
  box-shadow: 0 8rpx 0 #64748B, 0 16rpx 0 #64748B;
}

.empty-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
}

.empty-desc {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 创建按钮 — D方向：2px锐利方形 */
.empty-btn {
  background: #3B82F6;
  color: #FFFFFF;
  padding: 28rpx 72rpx;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.18);
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

.empty-btn:active {
  background: #2563EB;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.12);
}

/* ============ LOAD MORE ============ */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.load-more-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.no-more {
  padding: 32rpx;
  text-align: center;
}

.no-more text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* ============ VISITORS SECTION ============ */
.visitors-section {
  margin-top: 48rpx;
  padding-top: 48rpx;
  border-top: 2rpx solid #E2E8F0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 分区标题 — D方向：衬线字体 */
.section-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.section-arrow {
  font-size: 26rpx;
  color: #64748B;
}

/* 统计卡片 — C方向：暖调渐变底色 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(170deg, #FFFFFF 0%, #FEFCF7 100%);
  border-radius: 8rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.03), 0 1rpx 3rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #E2E8F0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 统计图标 — 品牌蓝 */
.icon-users {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-users::before,
.icon-users::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  top: 0;
  opacity: 0.55;
}

.icon-users::before {
  left: 0;
}

.icon-users::after {
  right: 0;
}

.icon-users .body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 24rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 12rpx 12rpx 0 0;
  opacity: 0.55;
}

.icon-eye {
  width: 36rpx;
  height: 24rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 12rpx 12rpx 0 0;
  position: relative;
  opacity: 0.55;
}

.icon-eye::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-add {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  position: relative;
  opacity: 0.55;
}

.icon-add::before,
.icon-add::after {
  content: '';
  position: absolute;
  background: #3B82F6;
}

.icon-add::before {
  width: 24rpx;
  height: 2rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.icon-add::after {
  width: 2rpx;
  height: 24rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: #E2E8F0;
}

/* ============ VISITOR LIST ============ */
.visitor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.visitor-item {
  display: flex;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.03), 0 1rpx 3rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #E2E8F0;
}

/* 访客头像 — 方形锐角 */
.visitor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.visitor-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
}

/* 访客默认头像图标 — 品牌蓝 */
.icon-user {
  width: 44rpx;
  height: 52rpx;
  position: relative;
}

.icon-user::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  opacity: 0.55;
}

.icon-user::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 28rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 14rpx 14rpx 0 0;
  opacity: 0.55;
}

.visitor-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.visitor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 访客等级徽章 */
.visitor-level-badge {
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.visitor-level-badge.level-1 {
  background: #F1F5F9;
  color: #94A3B8;
  border: 1rpx solid #E2E8F0;
}

/* 访客名称 — 衬线 */
.visitor-name {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.visitor-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.visitor-position {
  font-size: 26rpx;
  color: #64748B;
}

.visitor-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #64748B;
  padding: 4rpx 14rpx;
  background: #F1F5F9;
  border-radius: 4rpx;
}

.visit-count-tag {
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.06);
  font-weight: 500;
}

/* 操作按钮 — D方向：锐角 */
.visitor-button {
  padding: 16rpx 28rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
  transition: all 0.2s;
  align-self: center;
}

.visitor-button:active {
  transform: scale(0.95);
}

.visitor-button.primary {
  background: #3B82F6;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.16);
}

.visitor-button.primary:active {
  background: #2563EB;
  box-shadow: 0 2rpx 6rpx rgba(59, 130, 246, 0.1);
}

.visitor-button.secondary {
  background: #F1F5F9;
  color: #64748B;
}

.visitor-button.secondary:active {
  background: #E2E8F0;
}

.view-all-btn {
  text-align: center;
  padding: 32rpx;
  color: #94A3B8;
  font-size: 28rpx;
}

/* ============ PRIVACY POPUP ============ */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.privacy-popup {
  width: 100%;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.privacy-popup-header {
  padding: 40rpx 40rpx 24rpx;
  text-align: center;
}

.privacy-popup-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.privacy-popup-body {
  padding: 0 40rpx 32rpx;
}

.privacy-popup-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

.privacy-link {
  color: #3B82F6;
  font-weight: 500;
}

.privacy-popup-footer {
  display: flex;
  border-top: 2rpx solid #F1F5F9;
}

.privacy-btn-decline {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  font-size: 30rpx;
  color: #64748B;
  border-right: 2rpx solid #F1F5F9;
  transition: background 0.2s;
}

.privacy-btn-decline:active {
  background: #F8FAFC;
}

.privacy-btn-agree {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #3B82F6;
  background: transparent;
  line-height: normal;
}

.privacy-btn-agree::after {
  border: none;
}

.privacy-btn-agree:active {
  background: #F0F7FF;
}

/* ============ AGREEMENT FOOTER ============ */
.agreement-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0 calc(32rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
}

.agreement-link {
  font-size: 24rpx;
  color: #94A3B8;
}

.agreement-sep {
  font-size: 24rpx;
  color: #CBD5E1;
}

/* ============ CANVAS 卡片预览样式 ============ */

/* 隐藏的 Canvas 用于渲染 */
.hidden-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 800rpx;
  height: 400rpx;
  opacity: 0;
  pointer-events: none;
}

/* Canvas 渲染的卡片预览 */
.card-preview {
  width: 100%;
  height: auto;
  border-radius: 8rpx;
  overflow: hidden;
}

/* 传统卡片内容（降级方案） */
.card-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

/* 卡片渲染中加载状态 */
.card-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 375rpx;
  background: #f8fafc;
  border-radius: 8rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
