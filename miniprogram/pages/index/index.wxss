page {
  background: linear-gradient(180deg, #EEF2FF 0%, #F5F5F5 100%);
  min-height: 100vh;
}

.container {
  padding: 0 24rpx 48rpx;
  padding-top: calc(var(--status-bar-height) + 20rpx);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
}

.subtitle {
  font-size: 26rpx;
  color: #94A3B8;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.header-right {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.header-btn-icon {
  font-size: 36rpx;
  color: #64748B;
}

/* 头部按钮容器 */
.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 头部按钮图标包装 */
.header-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.header-icon-wrapper.small {
  width: 48rpx;
  height: 48rpx;
}

/* 桌面图标 */
.icon-desktop {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.icon-desktop::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 16rpx;
  border: 3rpx solid #3B82F6;
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
}

.icon-desktop::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: #3B82F6;
  border-radius: 2rpx;
}

/* 新增按钮图标包装 */
.add-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.3);
}

.add-icon {
  font-size: 36rpx;
  font-weight: 400;
  color: #fff;
  line-height: 1;
}

.search-bar {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.search-icon {
  font-size: 32rpx;
  color: #94A3B8;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
}

.card-list {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 悬浮发名片按钮 */
.float-add-btn {
  position: sticky;
  top: calc(var(--status-bar-height) + 140rpx);
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  border-radius: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  margin-bottom: 16rpx;
}

.float-add-icon {
  font-size: 28rpx;
  font-weight: 400;
  color: #fff;
  line-height: 1;
}

.float-add-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.card-item {
  margin-bottom: 24rpx;
}

.card-wrapper {
  position: relative;
  background: linear-gradient(135deg, #F0F9FF 0%, #FDF6E3 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.card-avatar-wrapper {
  flex-shrink: 0;
}

.card-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #F1F5F9;
}

.card-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  gap: 8rpx;
}

.card-name {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
}

.card-position {
  font-size: 26rpx;
  color: #64748B;
}

.card-divider {
  height: 2rpx;
  background: rgba(0, 0, 0, 0.08);
  margin: 0 0 24rpx 0;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-company {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  text-align: left;
}

.card-contact {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.contact-item {
  display: flex;
  justify-content: flex-end;
  font-size: 26rpx;
  color: #475569;
}

.card-arrow-wrapper {
  position: absolute;
  top: 50%;
  right: 24rpx;
  transform: translateY(-50%);
}

.card-arrow {
  font-size: 44rpx;
  color: #94A3B8;
}

.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

.load-more-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.no-more {
  padding: 32rpx;
  text-align: center;
  color: #CBD5E1;
  font-size: 24rpx;
}

.visitors-section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.section-arrow {
  font-size: 26rpx;
  color: #3B82F6;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.stat-item:active {
  background: #F8FAFC;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.recent-visitors {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.visitors-list {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.visitors-list::-webkit-scrollbar {
  display: none;
}

.visitor-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.visitor-avatar-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0F2FE 0%, #FEF3C7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.visitor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F1F5F9;
}

.visitor-name {
  font-size: 24rpx;
  color: #475569;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #E0F2FE 0%, #FEF3C7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon text {
  font-size: 64rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  background: #FEF2F2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.error-icon text {
  font-size: 48rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #DC2626;
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  margin-bottom: 32rpx;
}

.error-btn {
  background: #fff;
  color: #3B82F6;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  border: 2rpx solid #3B82F6;
}

.privacy-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.privacy-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 40rpx;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  text-align: center;
  margin-bottom: 24rpx;
}

.privacy-desc {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

.privacy-links {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.privacy-link {
  flex: 1;
  text-align: center;
  color: #3B82F6;
  font-size: 26rpx;
  padding: 16rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
}

.privacy-buttons {
  display: flex;
  gap: 20rpx;
}

.privacy-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.privacy-btn-primary {
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  color: #fff;
}

.privacy-btn-secondary {
  background: #F1F5F9;
  color: #64748B;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  z-index: 100;
}

.add-btn-icon {
  font-size: 48rpx;
  color: #fff;
}

.hidden-canvas {
  position: fixed;
  top: -1000px;
  left: -1000px;
  width: 1px;
  height: 1px;
  opacity: 0;
}