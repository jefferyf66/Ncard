<view class="container">
  <view class="page-header">
    <text class="page-title">名片识别</text>
    <text class="page-desc">上传名片图片，智能识别信息</text>
  </view>

  <view class="scan-area" bindtap="chooseImage">
    <view class="scan-frame">
      <view class="scan-line" wx:if="{{!ocrResult}}"></view>
      <view class="corner top-left"></view>
      <view class="corner top-right"></view>
      <view class="corner bottom-left"></view>
      <view class="corner bottom-right"></view>
      <view class="scan-icon">
        <view class="icon-camera"></view>
      </view>
      <text class="scan-hint">点击或上传图片</text>
    </view>
  </view>

  <view class="action-buttons">
    <view class="action-btn primary" bindtap="chooseImage">
      <view class="btn-icon-wrap">
        <view class="icon-camera"></view>
      </view>
      <text class="btn-text">拍照/相册</text>
    </view>
    <view class="action-btn secondary" bindtap="goToHistory">
      <view class="btn-icon-wrap">
        <view class="icon-list"></view>
      </view>
      <text class="btn-text">识别记录</text>
    </view>
  </view>

  <view class="ocr-result" wx:if="{{ocrResult}}">
    <view class="result-header">
      <text class="result-title">识别结果</text>
      <view class="result-close" bindtap="clearResult">×</view>
    </view>
    <view class="result-card">
      <view class="result-item">
        <text class="result-label">姓名</text>
        <input class="result-input" value="{{ocrResult.name}}" data-field="name" bindinput="onResultInput" placeholder="请输入姓名" />
      </view>
      <view class="result-item">
        <text class="result-label">职位</text>
        <input class="result-input" value="{{ocrResult.position}}" data-field="position" bindinput="onResultInput" placeholder="请输入职位" />
      </view>
      <view class="result-item">
        <text class="result-label">公司</text>
        <input class="result-input" value="{{ocrResult.company}}" data-field="company" bindinput="onResultInput" placeholder="请输入公司" />
      </view>
      <view class="result-item">
        <text class="result-label">电话</text>
        <input class="result-input" value="{{ocrResult.phone}}" data-field="phone" bindinput="onResultInput" type="number" placeholder="请输入电话" />
      </view>
      <view class="result-item">
        <text class="result-label">邮箱</text>
        <input class="result-input" value="{{ocrResult.email}}" data-field="email" bindinput="onResultInput" placeholder="请输入邮箱" />
      </view>
      <view class="result-item">
        <text class="result-label">地址</text>
        <textarea class="result-textarea" value="{{ocrResult.address}}" data-field="address" bindinput="onResultInput" placeholder="请输入地址" />
      </view>
    </view>
    <view class="result-actions">
      <view class="action-btn-outline" bindtap="clearResult">取消</view>
      <view class="action-btn-solid" bindtap="saveOcrResult">保存名片</view>
    </view>
  </view>

  <view class="history-section" wx:if="{{showHistory && historyList.length > 0}}">
    <view class="section-header">
      <text class="section-title">识别记录</text>
      <text class="section-close" bindtap="closeHistory">关闭</text>
    </view>
    <view class="history-list">
      <view 
        class="history-item" 
        wx:for="{{historyList}}" 
        wx:key="_id"
        bindtap="loadHistoryResult"
        data-result="{{item.result}}"
      >
        <view class="history-avatar">
          <view class="icon-user"></view>
        </view>
        <view class="history-info">
          <text class="history-name">{{item.result.name || '未识别'}}</text>
          <text class="history-company">{{item.result.company || ''}}</text>
        </view>
        <text class="history-time">{{item.createTimeStr}}</text>
      </view>
    </view>
  </view>
</view>
