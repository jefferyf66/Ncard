.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F9FAFB 0%, #FFFFFF 100%);
  padding: 24rpx;
}

.page-header {
  padding: 40rpx 0 32rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 28rpx;
  color: #9CA3AF;
}

.scan-area {
  margin-bottom: 32rpx;
}

.scan-frame {
  width: 100%;
  height: 400rpx;
  border: 4rpx dashed #D1D5DB;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: border-color 0.3s;
}

.scan-frame:active {
  border-color: #3B82F6;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, #3B82F6, transparent);
  animation: scan 2s linear infinite;
}

@keyframes scan {
  0% { top: 0; }
  100% { top: 100%; }
}

.corner {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #3B82F6;
}

.corner.top-left {
  top: 16rpx;
  left: 16rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 12rpx 0 0 0;
}

.corner.top-right {
  top: 16rpx;
  right: 16rpx;
  border-left: none;
  border-bottom: none;
  border-radius: 0 12rpx 0 0;
}

.corner.bottom-left {
  bottom: 16rpx;
  left: 16rpx;
  border-right: none;
  border-top: none;
  border-radius: 0 0 0 12rpx;
}

.corner.bottom-right {
  bottom: 16rpx;
  right: 16rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 12rpx 0;
}

.scan-icon {
  width: 100rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.icon-camera {
  width: 60rpx;
  height: 50rpx;
  border: 3rpx solid #3B82F6;
  border-radius: 8rpx;
  position: relative;
}

.icon-camera::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-camera::after {
  content: '';
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #3B82F6;
  border-radius: 50%;
  background: #3B82F6;
}

.scan-hint {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 24rpx;
  border-radius: 20rpx;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.primary {
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F3F4F6;
}

.action-btn.secondary {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.2);
}

.btn-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary .btn-icon-wrap {
  background: #F3F4F6;
}

.action-btn.secondary .btn-icon-wrap {
  background: rgba(255, 255, 255, 0.2);
}

.icon-list {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-list::before,
.icon-list::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 3rpx;
}

.action-btn.primary .icon-list::before,
.action-btn.primary .icon-list::after {
  background: #3B82F6;
}

.action-btn.secondary .icon-list::before,
.action-btn.secondary .icon-list::after {
  background: #FFFFFF;
}

.icon-list::before {
  top: 12rpx;
}

.icon-list::after {
  top: 28rpx;
}

.icon-list .bullet {
  position: absolute;
  top: 12rpx;
  left: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  box-shadow: 0 16rpx 0 currentColor;
}

.action-btn.primary .icon-list .bullet {
  background: #3B82F6;
  color: #3B82F6;
}

.action-btn.secondary .icon-list .bullet {
  background: #FFFFFF;
  color: #FFFFFF;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary .btn-text {
  color: #374151;
}

.action-btn.secondary .btn-text {
  color: #FFFFFF;
}

.ocr-result {
  margin-bottom: 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.result-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #3B82F6;
}

.result-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F3F4F6;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  width: 140rpx;
  flex-shrink: 0;
}

.result-input {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
  text-align: right;
  padding: 12rpx 20rpx;
  background: #F9FAFB;
  border-radius: 10rpx;
}

.result-textarea {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
  padding: 16rpx 20rpx;
  background: #F9FAFB;
  border-radius: 10rpx;
  min-height: 100rpx;
  text-align: right;
}

.result-input::placeholder,
.result-textarea::placeholder {
  color: #9CA3AF;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.action-btn-outline {
  flex: 1;
  background: #FFFFFF;
  border: 2rpx solid #93C5FD;
  border-radius: 44rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #3B82F6;
  transition: background 0.2s;
}

.action-btn-outline:active {
  background: #EFF6FF;
}

.action-btn-solid {
  flex: 2;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  border-radius: 44rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.2);
  transition: transform 0.2s;
}

.action-btn-solid:active {
  transform: scale(0.98);
}

.history-section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.section-close {
  font-size: 28rpx;
  color: #3B82F6;
}

.history-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F3F4F6;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
  transition: background 0.2s;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #F9FAFB;
}

.history-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-user {
  width: 44rpx;
  height: 52rpx;
  position: relative;
}

.icon-user::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-user::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 28rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 14rpx 14rpx 0 0;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.history-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.history-company {
  font-size: 26rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 24rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}
