<view class="container">
  <!-- 加载态 -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
  <view class="section-header">
    <text class="section-title">名片数据</text>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-value">{{stats.visitors}}</text>
      <text class="stat-label">我的访客</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.viewed}}</text>
      <text class="stat-label">多次来访</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.newCards}}</text>
      <text class="stat-label">名片数</text>
    </view>
  </view>

  <view class="section-title-row">
    <text class="section-title">最近访客</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">
      <view class="icon-users-empty"></view>
    </view>
    <text class="empty-title">暂无访客数据</text>
    <text class="empty-desc">分享您的名片后，访客数据将会出现在这里</text>
  </view>

  <!-- 访客列表 -->
  <view class="visitor-list" wx:else>
    <view 
      class="visitor-item" 
      wx:for="{{visitors}}" 
      wx:key="id"
      bindtap="goToProfile"
      data-item="{{item}}"
    >
      <view class="visitor-avatar">
        <image 
          wx:if="{{item.avatar}}"
          class="visitor-avatar-img" 
          src="{{item.avatar}}" 
          mode="aspectFill"
        ></image>
        <view class="icon-user" wx:else></view>
      </view>
      <view class="visitor-info">
        <view class="visitor-header">
          <text class="visitor-name">{{item.name}}</text>
          <view class="visitor-level-badge level-{{item.visitorLevel}}" wx:if="{{item.visitorLevel < 3}}">
            <text wx:if="{{item.visitorLevel === 2}}">已授权</text>
            <text wx:else>匿名</text>
          </view>
          <text class="visitor-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
        </view>
        <text class="visitor-position" wx:if="{{item.position}}">{{item.position}}</text>
        <text class="visitor-company" wx:if="{{item.company}}">{{item.company}}</text>
        <view class="visitor-tags">
          <text class="tag visit-count-tag" wx:if="{{item.visitCount > 1}}">来访{{item.visitCount}}次</text>
          <text class="tag" wx:for="{{item.actions}}" wx:key="index">{{item}}</text>
        </view>
        <view class="visitor-meta">
          <text class="visitor-time">{{item.lastVisit}}</text>
          <text class="visitor-desc">{{item.description}}</text>
        </view>
      </view>
      <view 
        class="visitor-button {{item.buttonType}}" 
        catchtap="handleAction"
        data-item="{{item}}"
      >
        {{item.buttonText}}
      </view>
    </view>
  </view>

  </block>
</view>
