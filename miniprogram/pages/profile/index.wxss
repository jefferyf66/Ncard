/* ==========================================
   Ncard 个人中心 · 品牌蓝设计系统
   ========================================== */

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: linear-gradient(175deg, #EFF6FF 0%, #F8FAFC 40%, #FEFCF7 100%);
}

/* ============ USER CARD ============ */
.user-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.04);
  border: 2rpx solid #E2E8F0;
}

.user-bg {
  height: 120rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
}

.user-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 28rpx 28rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 4rpx;
  border: 4rpx solid #FFFFFF;
  background: #F1F5F9;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding-top: 48rpx;
}

.user-name {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
}

.user-desc {
  font-size: 26rpx;
  color: #64748B;
}

.login-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  border-radius: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.2);
  margin-top: 48rpx;
}

.login-btn:active {
  background: #2563EB;
  transform: scale(0.97);
}

.login-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ============ STATS CARD ============ */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(170deg, #FFFFFF 0%, #FEFCF7 100%);
  border-radius: 8rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.03);
  border: 2rpx solid #E2E8F0;
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 4rpx;
  background: rgba(59, 130, 246, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-card {
  width: 36rpx;
  height: 44rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 8rpx;
  right: 8rpx;
  height: 2rpx;
  background: #3B82F6;
  box-shadow: 0 8rpx 0 #3B82F6;
}

.icon-users {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-users::before,
.icon-users::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  top: 0;
}

.icon-users::before { left: 0; }
.icon-users::after { right: 0; }

.icon-camera {
  width: 40rpx;
  height: 36rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-camera::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #0F172A;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
}

/* ============ MENU GROUP ============ */
.menu-group {
  margin-bottom: 24rpx;
}

.menu-header {
  padding: 0 8rpx 16rpx;
}

.menu-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.menu-card {
  background: #FFFFFF;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(29, 78, 216, 0.03);
  border: 2rpx solid #E2E8F0;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border-bottom: 2rpx solid #F1F5F9;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8FAFC;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 4rpx;
  background: rgba(59, 130, 246, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #94A3B8;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-subtext {
  font-size: 26rpx;
  color: #94A3B8;
}

.theme-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* ============ ICONS ============ */
.icon-list,
.icon-palette,
.icon-star,
.icon-trash,
.icon-info {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-list::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  height: 24rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
}

.icon-palette {
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-palette::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 12rpx;
  height: 12rpx;
  background: #3B82F6;
  border-radius: 50%;
}

.icon-palette::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 12rpx;
  height: 12rpx;
  background: #D97706;
  border-radius: 50%;
}

.icon-star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 20rpx solid #3B82F6;
}

.icon-trash::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 2rpx solid #EF4444;
  border-radius: 4rpx;
}

.icon-trash::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 4rpx;
  background: #EF4444;
  border-radius: 2rpx;
}

.icon-info {
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-info::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 16rpx;
  background: #3B82F6;
}

.icon-check {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.icon-check::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #3B82F6;
  border-bottom: 3rpx solid #3B82F6;
  transform: translate(-50%, -70%) rotate(-45deg);
}

/* ============ VERSION ============ */
.version-info {
  text-align: center;
  padding: 32rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ============ MODALS ============ */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.modal-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
  overflow-y: auto;
}

.card-modal {
  max-height: 60vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.modal-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.modal-close {
  font-size: 40rpx;
  color: #94A3B8;
  padding: 8rpx;
}

/* ============ THEME PICKER ============ */
.theme-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 8rpx 0;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.theme-option.active {
  background: rgba(59, 130, 246, 0.04);
  border-color: #3B82F6;
}

.theme-color {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.theme-name {
  font-size: 24rpx;
  color: #334155;
  font-weight: 500;
}

/* ============ CARD PICKER ============ */
.card-scroll {
  max-height: 360rpx;
}

.picker-card-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.picker-card-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid #E2E8F0;
  transition: all 0.2s;
}

.picker-card-item.selected {
  border-color: #3B82F6;
  background: rgba(59, 130, 246, 0.03);
}

.picker-card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 4rpx;
  background: #F1F5F9;
}

.picker-card-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.picker-card-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #0F172A;
}

.picker-card-company {
  font-size: 24rpx;
  color: #64748B;
}

.picker-card-check {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
