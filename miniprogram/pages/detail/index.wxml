<view class="container" wx:if="{{card.name}}">
  <view class="card-preview">
    <view class="card-header">
      <image class="avatar" src="{{card.avatar || '../../images/avatar.png'}}" mode="aspectFill"></image>
      <view class="name-info">
        <text class="name">{{card.name}}</text>
        <text class="position" wx:if="{{card.position}}">{{card.position}}</text>
        <text class="company" wx:if="{{card.company}}">{{card.company}}</text>
      </view>
    </view>
    
    <view class="card-divider"></view>
    
    <view class="contact-section">
      <view class="contact-item" wx:if="{{card.phone}}" bindtap="copyPhone">
        <view class="contact-icon-wrapper">📞</view>
        <view class="contact-content">
          <text class="contact-label">电话</text>
          <text class="contact-value">{{card.phone}}</text>
        </view>
        <view class="copy-btn">复制</view>
      </view>
      
      <view class="contact-item" wx:if="{{card.email}}" bindtap="copyEmail">
        <view class="contact-icon-wrapper">✉️</view>
        <view class="contact-content">
          <text class="contact-label">邮箱</text>
          <text class="contact-value">{{card.email}}</text>
        </view>
        <view class="copy-btn">复制</view>
      </view>
      
      <view class="contact-item" wx:if="{{card.address}}" bindtap="copyAddress">
        <view class="contact-icon-wrapper">📍</view>
        <view class="contact-content">
          <text class="contact-label">地址</text>
          <text class="contact-value">{{card.address}}</text>
        </view>
        <view class="copy-btn">复制</view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <view class="action-btn primary" bindtap="goToEdit">
      <text class="action-icon">✏️</text>
      <text class="action-text">编辑</text>
    </view>
    <view class="action-btn" bindtap="shareCard">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
    <view class="action-btn" bindtap="saveToContact" wx:if="{{card.phone}}">
      <text class="action-icon">📱</text>
      <text class="action-text">保存通讯录</text>
    </view>
    <view class="action-btn danger" bindtap="deleteCard">
      <text class="action-icon">🗑️</text>
      <text class="action-text">删除</text>
    </view>
  </view>

  <view class="create-time" wx:if="{{card.createTime}}">
    <text>创建于 {{createTimeStr}}</text>
  </view>
</view>

<view class="empty-state" wx:else>
  <text class="empty-text">名片不存在</text>
</view>