.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #F9FAFB;
}

.card-preview {
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  color: #FFFFFF;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.3);
}

.card-header {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
}

.name-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
}

.position {
  font-size: 28rpx;
  opacity: 0.9;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.company {
  font-size: 26rpx;
  opacity: 0.8;
}

.card-divider {
  height: 2rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 -32rpx;
}

.contact-section {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.contact-item:active {
  background: rgba(255, 255, 255, 0.15);
}

.contact-icon-wrapper {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.contact-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.contact-label {
  font-size: 22rpx;
  opacity: 0.7;
}

.contact-value {
  font-size: 28rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 8rpx;
  color: #FFFFFF;
}

.action-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  min-width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-btn:active {
  background: #F3F4F6;
}

.action-btn.primary {
  background: #3B82F6;
}

.action-btn.primary .action-text {
  color: #FFFFFF;
}

.action-btn.danger .action-icon {
  font-size: 44rpx;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #4B5563;
  font-weight: 500;
}

.create-time {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.empty-text {
  font-size: 32rpx;
  color: #9CA3AF;
}