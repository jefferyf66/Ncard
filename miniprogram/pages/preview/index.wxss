.container {
  min-height: 100vh;
  background: linear-gradient(175deg, #FAFBFC 0%, #FEFCF9 30%, #F6F8FC 100%);
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.card-preview {
  margin-bottom: 32rpx;
}

.card-content {
  background: linear-gradient(165deg, #FFFFFF 0%, #FEFCF9 30%, #F8FAFF 100%);
  border-radius: 28rpx;
  padding: 40rpx;
  padding-left: 48rpx;
  box-shadow: 0 2rpx 24rpx rgba(0, 0, 0, 0.04), 0 1rpx 4rpx rgba(29, 78, 216, 0.03);
  border: 2rpx solid rgba(29, 78, 216, 0.06);
  position: relative;
}

/* 左侧品牌色装饰条 */
.card-content::before {
  content: '';
  position: absolute;
  top: 32rpx;
  bottom: 32rpx;
  left: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #3B82F6 0%, #60A5FA 50%, #3B82F6 100%);
  border-radius: 0 3rpx 3rpx 0;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 4rpx;
  border: 3rpx solid rgba(59, 130, 246, 0.15);
  background: linear-gradient(135deg, #EFF6FF 0%, #F8FAFC 100%);
}

.name-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name {
  font-size: 44rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: 3rpx;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.position {
  font-size: 26rpx;
  color: #3B82F6;
  padding: 8rpx 20rpx;
  background: rgba(59, 130, 246, 0.06);
  border-radius: 4rpx;
  align-self: flex-start;
  font-weight: 500;
}

.card-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #E2E8F0 20%, #E2E8F0 80%, transparent 100%);
  margin: 0 -40rpx 28rpx;
}

.company {
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
  margin-bottom: 28rpx;
  display: block;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.contact-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 4rpx;
  border-left: 4rpx solid transparent;
  transition: all 0.2s;
}

.contact-row:active {
  background: linear-gradient(135deg, #EFF6FF 0%, #F1F5F9 100%);
  border-left-color: #3B82F6;
}

.contact-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-phone {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  position: relative;
}

.icon-phone::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  height: 2rpx;
  background: #3B82F6;
}

.icon-phone::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 12rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 0 0 10rpx 10rpx;
  border-top: none;
}

.icon-mail {
  width: 40rpx;
  height: 32rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 6rpx;
  position: relative;
}

.icon-mail::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 10rpx solid #3B82F6;
}

.icon-map {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-map::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
}

.icon-map::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  background: #3B82F6;
}

.contact-text {
  font-size: 28rpx;
  color: #334155;
  text-align: left;
  flex: 1;
}

.section-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F1F5F9;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(59, 130, 246, 0.06);
  border-radius: 4rpx;
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.section-count {
  font-size: 26rpx;
  color: #3B82F6;
  background: rgba(59, 130, 246, 0.06);
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.icon-briefcase {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-briefcase::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 6rpx;
  right: 6rpx;
  height: 4rpx;
  background: #3B82F6;
}

.icon-paperclip {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-paperclip::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #3B82F6;
  border-right: none;
  border-bottom: none;
  border-radius: 4rpx 0 0 0;
}

.icon-paperclip::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 4rpx;
  background: #3B82F6;
}

.icon-file {
  width: 44rpx;
  height: 52rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-file::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
}

.icon-file::after {
  content: '';
  position: absolute;
  top: 34rpx;
  left: 8rpx;
  right: 8rpx;
  height: 2rpx;
  background: #3B82F6;
  box-shadow: 0 8rpx 0 #3B82F6;
}

.icon-download {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.icon-download::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #3B82F6;
}

.icon-download::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 2rpx;
  right: 2rpx;
  height: 14rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
}

.experience-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.experience-item {
  padding: 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 8rpx;
  border-left: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.experience-item:active {
  border-left-color: #3B82F6;
}

.exp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.exp-company {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.exp-period {
  font-size: 24rpx;
  color: #94A3B8;
}

.exp-position {
  font-size: 26rpx;
  color: #3B82F6;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.exp-desc {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

.intro-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 8rpx;
}

.attach-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.attach-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.attach-name {
  font-size: 28rpx;
  color: #0F172A;
}

.attach-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.attach-action {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.link-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #3B82F6;
}

.link-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.link-icon-wrap.website {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
}

.icon-wechat {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 10rpx;
  position: relative;
}

.icon-wechat::before,
.icon-wechat::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 50%;
}

.icon-wechat::before {
  width: 14rpx;
  height: 14rpx;
  top: 8rpx;
  left: 8rpx;
}

.icon-wechat::after {
  width: 18rpx;
  height: 18rpx;
  bottom: 8rpx;
  right: 6rpx;
}

.icon-globe {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
  position: relative;
}

.icon-globe::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 2rpx;
  right: 2rpx;
  height: 2rpx;
  background: #FFFFFF;
  transform: translateY(-50%);
}

.icon-globe::after {
  content: '';
  position: absolute;
  top: 2rpx;
  bottom: 2rpx;
  left: 50%;
  width: 2rpx;
  height: auto;
  background: #FFFFFF;
  transform: translateX(-50%);
}

.link-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.link-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.link-desc {
  font-size: 24rpx;
  color: #64748B;
}

.link-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-arrow-right {
  width: 24rpx;
  height: 24rpx;
  border-top: 2rpx solid #3B82F6;
  border-right: 2rpx solid #3B82F6;
  transform: rotate(45deg);
}

.function-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 0;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F3F4F6;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.func-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
  background: rgba(59, 130, 246, 0.06);
}

.func-icon-wrap:active {
  transform: scale(0.92);
}

.icon-edit {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-edit::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
}

.icon-edit::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 20rpx;
  height: 6rpx;
  background: #3B82F6;
  transform: rotate(-45deg);
  transform-origin: left center;
}

.icon-save {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-save::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 14rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
}

.icon-save::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 0;
  right: 0;
  height: 14rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 0 0 4rpx 4rpx;
}

.icon-trash {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-trash::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  border: 2rpx solid #EF4444;
  border-radius: 4rpx;
}

.icon-trash::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 6rpx;
  background: #EF4444;
  border-radius: 2rpx;
}

.func-text {
  font-size: 26rpx;
  color: #475569;
}

.share-btn {
  width: 100%;
  background: linear-gradient(160deg, #3B82F6 0%, #2563EB 100%);
  border-radius: 4rpx;
  padding: 36rpx;
  border: none;
  margin: 0;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.16), 0 1rpx 4rpx rgba(59, 130, 246, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
}

.share-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.14);
}

.share-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.icon-share {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

/* 左上角箭头 */
.icon-share::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #FFFFFF;
  border-left: 2rpx solid #FFFFFF;
}

/* 右下角箭头 */
.icon-share::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  border-bottom: 2rpx solid #FFFFFF;
  border-right: 2rpx solid #FFFFFF;
}

.share-text {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.icon-alert {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #94A3B8;
  border-radius: 50%;
  position: relative;
}

.icon-alert::after {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 24rpx;
  background: #94A3B8;
}

.error-text {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(160deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.12);
}

.delete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.modal-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: transform 0.2s;
}

.modal-btn:active {
  transform: scale(0.98);
}

.modal-btn.cancel {
  background: #F1F5F9;
  color: #475569;
}

.modal-btn.confirm {
  background: #EF4444;
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.15);
}
