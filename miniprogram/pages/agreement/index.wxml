<view class="agreement-container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 'privacy' ? 'tab-active' : ''}}" 
      bindtap="switchTab" 
      data-tab="privacy"
    >
      <text>隐私政策</text>
    </view>
    <view 
      class="tab-item {{activeTab === 'service' ? 'tab-active' : ''}}" 
      bindtap="switchTab" 
      data-tab="service"
    >
      <text>用户服务协议</text>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content-area">
    <rich-text wx:if="{{activeTab === 'privacy'}}" nodes="{{privacyContent}}"></rich-text>
    <rich-text wx:else nodes="{{serviceContent}}"></rich-text>
  </view>
</view>
