<view class="page-container">
  <view class="header">
    <view class="header-title">名片夹</view>
    <view class="header-count">{{cards.length}} 张名片</view>
  </view>

  <view class="card-list">
    <view 
      wx:for="{{cards}}" 
      wx:key="_id" 
      class="card-item"
      bindtap="goToPreview"
      data-id="{{item._id}}"
    >
      <image class="avatar" src="{{item.avatar || '../../images/avatar.png'}}" mode="aspectFill" binderror="onAvatarError" data-index="{{index}}"></image>
      <view class="card-info">
        <view class="name-row">
          <text class="name">{{item.name || '未填写'}}</text>
          <text class="position">{{item.position || ''}}</text>
        </view>
        <text class="company">{{item.company || ''}}</text>
        <view class="contact-info">
          <view class="contact-item" wx:if="{{item.phone}}">
            <text class="contact-icon">📞</text>
            <text class="contact-text">{{item.phone}}</text>
          </view>
          <view class="contact-item" wx:if="{{item.email}}">
            <text class="contact-icon">✉️</text>
            <text class="contact-text">{{item.email}}</text>
          </view>
        </view>
      </view>
      <view class="card-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{cards.length === 0}}" class="empty-state">
    <view class="empty-icon">
      <text class="icon-text">👔</text>
    </view>
    <text class="empty-title">暂无名片</text>
    <text class="empty-desc">暂未保存他人名片，在预览页保存后即可在此查看</text>
  </view>
</view>