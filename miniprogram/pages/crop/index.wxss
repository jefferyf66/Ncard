/* ===== 全屏黑色背景 ===== */
page {
  background: #000000;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.crop-page {
  width: 100vw;
  height: 100vh;
  background: #000000;
  display: flex;
  flex-direction: column;
}

/* ===== 加载阶段 ===== */
.crop-loading-phase {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #000000;
}

.crop-load-image {
  width: 240rpx;
}

.crop-loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
  border-top-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  animation: cropSpin 1s linear infinite;
  margin-top: 48rpx;
  margin-bottom: 24rpx;
}

@keyframes cropSpin {
  to { transform: rotate(360deg); }
}

.crop-loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* ===== 裁切画布区 ===== */
.crop-canvas-area {
  position: relative;
  width: 100vw;
  height: 100vw;
  overflow: hidden;
  background: #111111;
}

/* movable-area */
.crop-movable-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.crop-movable-view {
  display: flex;
  align-items: center;
  justify-content: center;
}

.crop-image {
  display: block;
  pointer-events: none;
}

/* ===== 正方形遮罩：box-shadow 镂空 + 白色引导边框 ===== */
.crop-square-mask {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 0 9999rpx rgba(0, 0, 0, 0.6);
  z-index: 2;
  pointer-events: none;
}

/* ===== 九宫格辅助线 ===== */
.crop-grid {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
  pointer-events: none;
}

.crop-grid-h {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.18);
}

.crop-grid-h:first-child { top: 33.33%; }
.crop-grid-h:last-child  { top: 66.66%; }

.crop-grid-v {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1rpx;
  background: rgba(255, 255, 255, 0.18);
}

.crop-grid-v:first-child { left: 33.33%; }
.crop-grid-v:last-child  { left: 66.66%; }

/* ===== 提示文字 ===== */
.crop-hint {
  padding: 32rpx 0;
  text-align: center;
}

.crop-hint text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* ===== 底部操作栏 ===== */
.crop-bottom-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx 72rpx;
}

.crop-btn {
  padding: 24rpx 72rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.crop-btn.cancel {
  background: rgba(255, 255, 255, 0.15);
  margin-right: 80rpx;
}

.crop-btn.cancel text {
  color: rgba(255, 255, 255, 0.8);
}

.crop-btn.confirm {
  background: #3B82F6;
}

.crop-btn.confirm text {
  color: #FFFFFF;
}

.crop-btn:active {
  opacity: 0.7;
}

/* ===== 隐藏 canvas ===== */
.crop-canvas-hidden {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
}
