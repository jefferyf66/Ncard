.container {
  min-height: 100vh;
  background: linear-gradient(175deg, #FAFBFC 0%, #FEFCF9 30%, #F6F8FC 100%);
}

.page-content {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* ===== 头像区 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 48rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #F8FAFC 100%);
  border: 4rpx solid rgba(59, 130, 246, 0.12);
  transition: border-color 0.3s;
}

.avatar-wrapper:active .avatar {
  border-color: #3B82F6;
}

.avatar-mask {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mask-icon {
  width: 100%;
  height: 100%;
  background: #3B82F6;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.22);
  transition: transform 0.2s;
}

.mask-icon:active {
  transform: scale(0.9);
}

.icon-plus {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.icon-plus::before,
.icon-plus::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
}

.icon-plus::before {
  width: 24rpx;
  height: 2rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.icon-plus::after {
  width: 2rpx;
  height: 24rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.avatar-tip {
  font-size: 28rpx;
  color: #94A3B8;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F1F5F9;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  font-family: Georgia, 'Times New Roman', 'PingFang SC', serif;
}

.add-btn {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 500;
}

.form-group {
  padding: 8rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.label-wrapper {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.form-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
  flex-shrink: 0;
}

.required {
  color: #EF4444;
  font-size: 28rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  text-align: right;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 4rpx;
  transition: background 0.2s;
}

.form-input:focus {
  background: #FFFFFF;
  outline: 2rpx solid rgba(59, 130, 246, 0.3);
}

.form-input.input-error {
  color: #6B7280;
  background: #FEF2F2;
}

.form-input::placeholder {
  color: #94A3B8;
}

.form-textarea {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 4rpx;
  min-height: 160rpx;
  transition: background 0.2s;
}

.form-textarea:focus {
  background: #FFFFFF;
  outline: 2rpx solid rgba(59, 130, 246, 0.3);
}

.form-textarea::placeholder {
  color: #94A3B8;
}

.form-error {
  font-size: 24rpx;
  color: #EF4444;
  padding-top: 8rpx;
  text-align: right;
}

.form-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #E2E8F0 20%, #E2E8F0 80%, transparent 100%);
  margin: 8rpx 0;
}

/* ===== 经历编辑器 ===== */
.experience-editor {
  margin-top: 16rpx;
}

.exp-item {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.exp-item:active {
  border-left-color: #3B82F6;
}

.exp-row {
  margin-bottom: 16rpx;
}

.exp-row:last-child {
  margin-bottom: 0;
}

.exp-input {
  width: 100%;
  font-size: 28rpx;
  color: #0F172A;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  border: 2rpx solid #E2E8F0;
  transition: border-color 0.2s;
}

.exp-input:focus {
  border-color: #3B82F6;
}

.exp-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #0F172A;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  border: 2rpx solid #E2E8F0;
  min-height: 120rpx;
  transition: border-color 0.2s;
}

.exp-textarea:focus {
  border-color: #3B82F6;
}

.exp-delete {
  text-align: right;
  font-size: 24rpx;
  color: #EF4444;
  padding-top: 8rpx;
}

/* ===== 上传区 ===== */
.upload-area {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.upload-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 4rpx;
  border: 2rpx solid #E2E8F0;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #CBD5E1;
  border-radius: 4rpx;
  gap: 8rpx;
  transition: border-color 0.2s;
}

.upload-placeholder:active {
  border-color: #3B82F6;
}

.upload-placeholder text {
  font-size: 22rpx;
  color: #94A3B8;
}

.icon-upload {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-upload::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background: #3B82F6;
  transform: translate(-50%, -50%);
}

.icon-upload::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2rpx;
  height: 20rpx;
  background: #3B82F6;
  transform: translate(-50%, -50%);
}

/* ===== 附件编辑器 ===== */
.attachment-editor {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attach-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 8rpx;
  border-left: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.attach-item:active {
  border-left-color: #3B82F6;
}

.attach-icon-small {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-file {
  width: 36rpx;
  height: 44rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 4rpx;
  position: relative;
}

.icon-file::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 2rpx;
}

.icon-file::after {
  content: '';
  position: absolute;
  top: 28rpx;
  left: 6rpx;
  right: 6rpx;
  height: 2rpx;
  background: #3B82F6;
  box-shadow: 0 6rpx 0 #3B82F6;
}

.attach-name-small {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.attach-delete {
  font-size: 24rpx;
  color: #EF4444;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #94A3B8;
  padding: 32rpx;
}

/* ===== 底部操作栏 — 不透明 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 2rpx solid #F1F5F9;
  box-shadow: 0 -1rpx 8rpx rgba(0, 0, 0, 0.03);
}

/* 保存按钮 — 不透明纯色 */
.save-btn {
  background: #3B82F6;
  padding: 32rpx;
  text-align: center;
  border-radius: 4rpx;
  transition: background 0.2s, transform 0.2s;
}

.save-btn:active {
  background: #2563EB;
  transform: scale(0.99);
}

.btn-text {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ===== 加载态 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #94A3B8;
}
