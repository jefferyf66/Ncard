<view class="container">
  <view class="loading-state" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">еҠ иҪҪдё?..</text>
  </view>

  <view wx:else class="page-content">
    <view class="avatar-section">
      <view class="avatar-wrapper" catchtap="chooseAvatar" hover-class="avatar-wrapper-hover">
        <image 
          class="avatar" 
          src="{{avatar || '../../images/avatar.png'}}" 
          mode="aspectFill"
        ></image>
        <view class="avatar-mask">
          <view class="mask-icon">
            <view class="icon-plus"></view>
          </view>
        </view>
      </view>
      <text class="avatar-tip">зӮ№еҮ»жӣҙжҚўеӨҙеғҸ</text>
    </view>

    <view class="form-card">
      <view class="form-header">
        <text class="form-title">еҹәжң¬дҝЎжҒҜ</text>
      </view>
      
      <view class="form-group">
        <view class="form-item">
          <view class="label-wrapper">
            <text class="form-label">е§“еҗҚ</text>
            <text class="required">*</text>
          </view>
          <input 
            class="form-input {{errors.name ? 'input-error' : ''}}" 
            placeholder="иҜ·иҫ“е…Ҙе§“еҗ? 
            value="{{name}}" 
            bindinput="onNameInput" 
            maxlength="20"
          ></input>
        </view>
        <view class="form-error" wx:if="{{errors.name}}">{{errors.name}}</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">иҒҢдҪҚ</text>
          <input 
            class="form-input" 
            placeholder="иҜ·иҫ“е…ҘиҒҢдҪ? 
            value="{{position}}" 
            bindinput="onPositionInput" 
            maxlength="30"
          ></input>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <view class="label-wrapper">
            <text class="form-label">е…¬еҸё</text>
            <text class="required">*</text>
          </view>
          <input 
            class="form-input {{errors.company ? 'input-error' : ''}}" 
            placeholder="иҜ·иҫ“е…Ҙе…¬еҸёеҗҚз§? 
            value="{{company}}" 
            bindinput="onCompanyInput" 
            maxlength="50"
          ></input>
        </view>
        <view class="form-error" wx:if="{{errors.company}}">{{errors.company}}</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">з”өиҜқ</text>
          <input 
            class="form-input {{errors.phone ? 'input-error' : ''}}" 
            placeholder="иҜ·иҫ“е…ҘжүӢжңәеҸ·з ? 
            value="{{phone}}" 
            bindinput="onPhoneInput" 
            type="number"
            maxlength="11"
          ></input>
        </view>
        <view class="form-error" wx:if="{{errors.phone}}">{{errors.phone}}</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">йӮ®з®ұ</text>
          <input 
            class="form-input {{errors.email ? 'input-error' : ''}}" 
            placeholder="иҜ·иҫ“е…ҘйӮ®з®ұең°еқҖ" 
            value="{{email}}" 
            bindinput="onEmailInput" 
            maxlength="50"
          ></input>
        </view>
        <view class="form-error" wx:if="{{errors.email}}">{{errors.email}}</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">ең°еқҖ</text>
          <textarea 
            class="form-textarea" 
            placeholder="иҜ·иҫ“е…Ҙең°еқҖ" 
            value="{{address}}" 
            bindinput="onAddressInput" 
            maxlength="100"
            auto-height
          ></textarea>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">дёӘдәәд»Ӣз»Қ</text>
          <textarea 
            class="form-textarea" 
            placeholder="д»Ӣз»ҚдёҖдёӢжӮЁиҮӘе·ұ" 
            value="{{personalIntro}}" 
            bindinput="onPersonalIntroInput" 
            maxlength="500"
            auto-height
          ></textarea>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-item">
          <text class="form-label">дёҡеҠЎд»Ӣз»Қ</text>
          <textarea 
            class="form-textarea" 
            placeholder="д»Ӣз»ҚжӮЁзҡ„дёҡеҠЎиҢғеӣҙе’ҢиғҪеҠ? 
            value="{{businessIntro}}" 
            bindinput="onBusinessIntroInput" 
            maxlength="1000"
            auto-height
          ></textarea>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-header">
          <text class="form-title">иҝҮеҫҖз»ҸеҺҶ</text>
          <text class="add-btn" bindtap="addExperience">+ ж·»еҠ </text>
        </view>
        <view class="experience-editor">
          <view class="exp-item" wx:for="{{experiences}}" wx:key="index">
            <view class="exp-row">
              <input class="exp-input" placeholder="е…¬еҸёеҗҚз§°" value="{{item.company}}" bindinput="onExpInput" data-index="{{index}}" data-field="company" />
            </view>
            <view class="exp-row">
              <input class="exp-input" placeholder="иҒҢдҪҚ" value="{{item.position}}" bindinput="onExpInput" data-index="{{index}}" data-field="position" />
            </view>
            <view class="exp-row">
              <input class="exp-input" placeholder="ж—¶й—ҙпјҲеҰӮпј?020-2023пј? value="{{item.period}}" bindinput="onExpInput" data-index="{{index}}" data-field="period" />
            </view>
            <view class="exp-row">
              <textarea class="exp-textarea" placeholder="е·ҘдҪңжҸҸиҝ°" value="{{item.desc}}" bindinput="onExpInput" data-index="{{index}}" data-field="desc" />
            </view>
            <view class="exp-delete" bindtap="deleteExperience" data-index="{{index}}">еҲ йҷӨ</view>
          </view>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-header">
          <text class="form-title">е…¬дј—еҸ·дҝЎжҒ?/text>
        </view>
        <view class="form-item">
          <text class="form-label">е…¬дј—еҸ·еҗҚз§?/text>
          <input class="form-input" placeholder="иҫ“е…Ҙе…¬дј—еҸ·еҗҚз§? value="{{wechatOfficial.name}}" bindinput="onWechatInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">е…¬дј—еҸ·з®Җд»?/text>
          <input class="form-input" placeholder="з®Җзҹӯд»Ӣз»? value="{{wechatOfficial.desc}}" bindinput="onWechatInput" data-field="desc" />
        </view>
        <view class="form-item">
          <text class="form-label">е…¬дј—еҸ·й“ҫжҺ?/text>
          <input class="form-input" placeholder="https://mp.weixin.qq.com/..." value="{{wechatOfficial.url}}" bindinput="onWechatInput" data-field="url" />
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-header">
          <text class="form-title">е…¬еҸёдё»йЎө</text>
        </view>
        <view class="form-item">
          <text class="form-label">зҪ‘з«ҷеҗҚз§°</text>
          <input class="form-input" placeholder="иҫ“е…ҘзҪ‘з«ҷеҗҚз§°" value="{{companyWebsite.name}}" bindinput="onWebsiteInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">зҪ‘з«ҷең°еқҖ</text>
          <input class="form-input" placeholder="https://..." value="{{companyWebsite.url}}" bindinput="onWebsiteInput" data-field="url" />
        </view>
        <view class="form-item">
          <text class="form-label">зҪ‘з«ҷжҸҸиҝ°</text>
          <input class="form-input" placeholder="з®ҖзҹӯжҸҸиҝ? value="{{companyWebsite.desc}}" bindinput="onWebsiteInput" data-field="desc" />
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-group">
        <view class="form-header">
          <text class="form-title">еҗҚзүҮйҷ„д»¶</text>
          <text class="add-btn" bindtap="chooseAttachment">+ ж·»еҠ </text>
        </view>
        <view class="attachment-editor">
          <view class="attach-item" wx:for="{{attachments}}" wx:key="index">
            <view class="attach-icon-small">
              <view class="icon-file"></view>
            </view>
            <text class="attach-name-small">{{item.name}}</text>
            <view class="attach-delete" bindtap="deleteAttachment" data-index="{{index}}">еҲ йҷӨ</view>
          </view>
          <view class="empty-tip" wx:if="{{attachments.length === 0}}">жҡӮж— йҷ„д»¶пјҢзӮ№еҮ»дёҠж–№ж·»еҠ?/view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="save-btn" bindtap="saveCard">
      <text class="btn-text">{{isEdit ? 'дҝқеӯҳдҝ®ж”№' : 'дҝқеӯҳеҗҚзүҮ'}}</text>
    </view>
  </view>
</view>
